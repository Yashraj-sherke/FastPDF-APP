# FastPDF Keystore Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file as 'keystore.properties' and fill in your values.
# NEVER commit keystore.properties to version control!
#
# Generate a keystore:
#   keytool -genkey -v -keystore fastpdf-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias fastpdf
#
storeFile=fastpdf-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=fastpdf
keyPassword=YOUR_KEY_PASSWORD
