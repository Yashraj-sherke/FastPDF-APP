<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Scanned documents saved internally -->
    <files-path
        name="scans"
        path="scans/" />

    <!-- Tool outputs (merge, split, compress, convert, protect, watermark, OCR) -->
    <files-path
        name="tools_output"
        path="tools_output/" />

    <!-- Fallback for files created directly under filesDir -->
    <files-path
        name="internal_files"
        path="." />

    <!-- Cache for temporary files -->
    <cache-path
        name="cache"
        path="/" />

    <!-- External files directory -->
    <external-files-path
        name="external"
        path="." />
</paths>
